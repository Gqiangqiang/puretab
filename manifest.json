{
  "manifest_version": 3,
  "name": "纯页 PureTab - 极简新标签页",
  "version": "1.0.0",
  "description": "一款极简的新标签页扩展，提供时钟、搜索、快捷链接、主题与锁屏等基础功能。",
  "permissions": [
    "storage"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "puretab.18095691014@163.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
